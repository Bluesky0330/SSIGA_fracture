	double temp_all_1,temp_all_2,temp_all_3,temp_all,WK_CRACKPROP;
		temp_all_1 = P_1j_gradients_q2[iElementID][i_GP];
		temp_all_2 = P_2j_gradients_q2[iElementID][i_GP];
		temp_all_3 = P_3j_gradients_q2[iElementID][i_GP];
