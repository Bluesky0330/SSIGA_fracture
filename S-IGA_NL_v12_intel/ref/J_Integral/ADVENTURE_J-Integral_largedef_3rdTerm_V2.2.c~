    		z = Node_Coordinate[i][2];

    		xc= Node_Coordinate[cfn][0];
			yc = Node_Coordinate[cfn][1]; //基準にするき裂前縁の節点の座標
			zc = Node_Coordinate[cfn][2];

    		//Converting to local coords  局所座標系に座標変換
    		xx = ConvLocalCoords(localCoord0, x, y, z);
    		yy = ConvLocalCoords(localCoord1, x, y, z);
    		zz = ConvLocalCoords(localCoord2, x, y, z);
    		xxc = ConvLocalCoords(localCoord0, xc, yc, zc);
    		yyc = ConvLocalCoords(localCoord1, xc, yc, zc);
    		zzc = ConvLocalCoords(localCoord2, xc, yc, zc);

   
			CTOA_node[nn][0] = cfn;
	
			if(fabs(zz-zzc) < av_d*0.1 &&  fabs(xx-xxc) < av_d*1.5 && xxc-xx > 0 && fabs(yy-yyc) < av_d*0.1){ //CTOAの節点を探す条件、初期配置の要素サイズに合わせて変更して下さい
            
				if(CTOA_node[nn][1] = -1 ){
					CTOA_node[nn][1] = i;  
					Constant_term[nn] = localCoord1[0] * xc + localCoord1[1] * yc + localCoord1[2] * zc ;
            	}
				else if(CTOA_node[nn][1] != -1){
					CTOA_node[nn][2] = i; 
				}
        	}

			CTOA_node_coordinate0[nn][0] = Node_Coordinate[CTOA_node[nn][0]][0] + Displacement[CTOA_node[nn][0]][0];
			CTOA_node_coordinate0[nn][1] = Node_Coordinate[CTOA_node[nn][0]][1] + Displacement[CTOA_node[nn][0]][1];
			CTOA_node_coordinate0[nn][2] = Node_Coordinate[CTOA_node[nn][0]][2] + Displacement[CTOA_node[nn][0]][2];

			CTOA_node_coordinate1[nn][0] = Node_Coordinate[CTOA_node[nn][1]][0] + Displacement[CTOA_node[nn][1]][0];
			CTOA_node_coordinate1[nn][1] = Node_Coordinate[CTOA_node[nn][1]][1] + Displacement[CTOA_node[nn][1]][1];
			CTOA_node_coordinate1[nn][2] = Node_Coordinate[CTOA_node[nn][1]][2] + Displacement[CTOA_node[nn][1]][2];

			Distance1[nn] = fabs(localCoord1[0]*CTOA_node_coordinate1[nn][0] + localCoord1[1]*CTOA_node_coordinate1[nn][1] + localCoord1[2]*CTOA_node_coordinate1[nn][2] - Constant_term[nn])/sqrt(localCoord1[0]*localCoord1[0]+localCoord1[1]*localCoord1[1]+localCoord1[2]*localCoord1[2]);
			Distance2[nn] = sqrt((CTOA_node_coordinate1[nn][0]-CTOA_node_coordinate0[nn][0])*(CTOA_node_coordinate1[nn][0]-CTOA_node_coordinate0[nn][0]) +(CTOA_node_coordinate1[nn][1]-CTOA_node_coordinate0[nn][1]) * (CTOA_node_coordinate1[nn][1]-CTOA_node_coordinate0[nn][1])+(CTOA_node_coordinate1[nn][2]-CTOA_node_coordinate0[nn][2]) * (CTOA_node_coordinate1[nn][2]-CTOA_node_coordinate0[nn][2]));


  		}
		
	
	}


	for(n=0;n<Ncrack_node+1;n++){
		CTOA[n]=asin(Distance1[n]/Distance2[n]); 
	}
}

void Oudput_q_List(const char *fileName){
	FILE *fp;
  	fp = fopen(fileName, "w");
	int i,j,n;
	
	fprintf(fp,"%d\n",NNodes);
	for(n=0;n<Ncrack_node;n++){
		for(i=0;i<NNodes;i++){
			fprintf(fp,"%lf\n",q2[i][n]);
		}
	}

	for(n=0;n<Ncrack_node;n++){
		fprintf(fp,"%d\n",N_V_ep_Elements[n]);
		for(j=0;j<N_V_ep_Elements[n];j++){
			fprintf(fp,"%d\n",List_of_V_ep_Elements[n][j]); 
		}
	}


	fclose(fp);
}

void Output_CTOA_coordinate(const char *fileName){
	FILE *fp;
  	fp = fopen(fileName, "w");
	int i,j,n;


for(n=0;n<Ncrack_node+1;n++){

	fprintf(fp,"%d\n",n);
	fprintf(fp,"%d	%d\n",CTOA_node[n][0],CTOA_node[n][1]);
	fprintf(fp,"%lf	%lf	%lf\n",CTOA[n]*2,Distance1[n]*2,Distance2[n]*cos(CTOA[n]));
	fprintf(fp,"%lf	%lf	%lf\n",CTOA_node_coordinate0[n][0],CTOA_node_coordinate0[n][1],CTOA_node_coordinate0[n][2]);
	fprintf(fp,"%lf	%lf	%lf\n",CTOA_node_coordinate1[n][0],CTOA_node_coordinate1[n][1],CTOA_node_coordinate1[n][2]);

	}


}




