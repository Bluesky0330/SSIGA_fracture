	/*printf("PaiTan ( %lf %lf %lf ) DispGrad_1( %lf %lf %lf )DispGrad_2( %lf %lf %lf )DispGrad_3( %lf %lf %lf )Vector ( %lf %lf %lf ) = J3 %lf |",
