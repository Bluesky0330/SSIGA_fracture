	printf("q ( %lf %lf %lf ) vec1( %lf %lf %lf ) vec2( %lf %lf %lf )vec3( %lf %lf %lf )\n",gradients_q2[iElementID][i_GP][0],gradients_q2[iElementID][i_GP][1],gradients_q2[iElementID][i_GP][2],
