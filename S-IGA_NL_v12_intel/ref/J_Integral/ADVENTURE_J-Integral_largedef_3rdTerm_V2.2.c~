		//x1,x2,x3方向の勾配
		for( N = 0; N < N_IntegrationPoint; N++ ){
		  	Make_Gradient_Matrix_Hexa_8(B_1, B_2, B_3, Gxi[N], X ,&J );
			for( i = 0; i < NO_NODES_ON_ELEMENT_H8; i++ ){
				  W_grad_1[e][N] += B_1[0][i*3] * JW_on_ElementNodeId_s[i];
