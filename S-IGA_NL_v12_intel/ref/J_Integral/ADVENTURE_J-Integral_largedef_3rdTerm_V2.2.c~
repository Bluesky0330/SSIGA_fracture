/***********************************************************************
						以下新規関数
***********************************************************************/

double ComputeValueQFunc(double x, double y, double z,
			 double z0, double z2, double z1,
			 double xc, double yc, double zc,
			 double r0, double r1)
{
  	double xx = x - xc; double yy = y - yc; double zz = z - zc;
  	double rr, zzabs;
  	double qfunc=0.0;
  	double Eps = 0.0000000001;
  	zzabs = fabs(zz);
  	rr = sqrt(xx*xx + yy*yy);

  	/**************************************************************
		台形の下に長方形がついた形の積分領域。下図の感じ。①③がVεの領域。
			＿＿＿＿＿＿＿
			|②| ④ /⑤ /  6
			ーーーーーー-----
			|①|   ③  | 7
			ーーーーーー-----
	*******************************************************************/

  	if(rr <= r0 + Eps){
  		if( zzabs <= z0  ){
  			qfunc = 1.0;   //①
  			Search_AreaFlag = 1;
  		}
  		else if( (z0 - Eps < zzabs) && (zzabs <= z1 ) ){
  			qfunc = 1.0 * (z1 - (zzabs - z0)) / z1;     //③
  			Search_AreaFlag  =3;
  		}
  		else if( z1 - Eps < zzabs ){
  			qfunc = 0.0;
  			Search_AreaFlag  = 7;     //7
  		}
  	}
  	else if( (r0 < rr) && (rr <= r1 + Eps)){
  		if( zzabs <= z0 ){
  			qfunc = (r1 - rr) / (r1 - r0);        //②
  			Search_AreaFlag =2;
  		}
  		else if( (z0 - Eps < zzabs) && (zzabs <= z0 + (rr-r0)/(r1-r0) * z2 )){
  			qfunc = (r1 - rr) / (r1 - r0);        //④
  			Search_AreaFlag =4;
  		}
  		else if( (z0 + (rr-r0)/(r1-r0) * z2 - Eps) < zzabs && zzabs <= (z0 + z1 + (rr-r0)/(r1-r0) * z2 ) ){
  			qfunc = ((r1 - rr) / (r1 - r0)) * (z1 -(zzabs - z0 - (rr-r0)/(r1-r0)*z2))/z1;        //⑤
  			Search_AreaFlag =5;
  		}
  		else if( (z0 + z1 + (rr-r0)/(r1-r0) * z2 - Eps) < zzabs){
  			qfunc = 0.0;
  			Search_AreaFlag =6;    //soto
  		}
  	}
  	else if(r1 < rr){
  		qfunc =0.0;
  		Search_AreaFlag =6;;   //soto
  	}

  	if(qfunc> Eps && rr < Eps){
    		//printf("xx yy zz zzabs q %10.3e %10.3e %10.3e %10.3e %10.3e\n",xx,yy,zz,zzabs,qfunc);//printf("xc yc zc z %10.3e %10.3e %10.3e %10.3e\n",xc,yc,zc,z);
  	}
  return(qfunc);
}

