					 { 0.57735026918962584208,-0.57735026918962584208,-0.57735026918962584208},
					 {-0.57735026918962584208, 0.57735026918962584208,-0.57735026918962584208},
					 { 0.57735026918962584208, 0.57735026918962584208,-0.57735026918962584208},
